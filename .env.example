APP_ENV=local
LOG_LEVEL=INFO
SERVICE_NAME=payments-service
API_KEY=change-me

# Development-only database credentials.
POSTGRES_DB=payments
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional override. If omitted, the app builds it from POSTGRES_*.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/payments

# Development-only RabbitMQ credentials.
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_BROKER_PORT=5672
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# Optional override. If omitted, the app builds it from RabbitMQ env.
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

API_PORT=8000
WEBHOOK_ECHO_PORT=9000
SWAGGER_DEFAULT_WEBHOOK_URL=http://webhook-echo:9000/webhooks/payments
PAYMENTS_QUEUE=payments.new
PAYMENTS_EXCHANGE=payments.events
PAYMENTS_RETRY_EXCHANGE=payments.retry
PAYMENTS_DEAD_LETTER_EXCHANGE=payments.dlx
PAYMENTS_DEAD_LETTER_QUEUE=payments.dlq
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=100
PAYMENT_PROCESSING_MIN_SECONDS=2
PAYMENT_PROCESSING_MAX_SECONDS=5
PAYMENT_SUCCESS_RATE=0.9
MESSAGE_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1
WEBHOOK_TIMEOUT_SECONDS=5
